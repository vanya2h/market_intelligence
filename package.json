{
  "name": "market-intel",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "derivatives": "pnpm --filter @market-intel/pipeline derivatives",
    "etfs": "pnpm --filter @market-intel/pipeline etfs",
    "htf": "pnpm --filter @market-intel/pipeline htf",
    "sentiment": "pnpm --filter @market-intel/pipeline sentiment",
    "brief": "pnpm --filter @market-intel/pipeline brief",
    "notify": "pnpm --filter @market-intel/pipeline notify",
    "db:generate": "pnpm --filter @market-intel/pipeline db:generate",
    "db:migrate": "pnpm --filter @market-intel/pipeline db:migrate",
    "dev:api": "pnpm --filter @market-intel/api dev",
    "dev:web": "pnpm --filter @market-intel/web dev",
    "typecheck": "turbo typecheck",
    "build": "turbo build"
  },
  "devDependencies": {
    "@vanya2h/typescript-config": "^0.3.0",
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
