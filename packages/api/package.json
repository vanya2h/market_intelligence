{
  "name": "@market-intel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/lib/exports.ts",
    "./client": "./src/lib/client.ts",
    "./briefs": "./src/lib/briefs.ts"
  },
  "main": "src/lib/exports.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "prisma generate --schema=../pipeline/prisma/schema.prisma && tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/standard-validator": "~0.2.2",
    "@market-intel/pipeline": "workspace:*",
    "dotenv": "^16.4.5",
    "hono": "^4.7.0",
    "hono-openapi": "^1.3.0",
    "prisma": "^7.5.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=22.16"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
