generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ─── Core Enums ──────────────────────────────────────────────────────────────

enum Asset {
    BTC
    ETH
}

enum Dimension {
    DERIVATIVES
    ETFS
    HTF
    SENTIMENT
}

// ─── Per-Dimension Regime Enums ──────────────────────────────────────────────

enum PositioningRegime {
    CROWDED_LONG
    CROWDED_SHORT
    HEATING_UP
    POSITIONING_NEUTRAL
}

enum StressLevel {
    CAPITULATION
    UNWINDING
    DELEVERAGING
    STRESS_NONE
}

enum EtfRegime {
    STRONG_INFLOW
    STRONG_OUTFLOW
    REVERSAL_TO_INFLOW
    REVERSAL_TO_OUTFLOW
    ETF_NEUTRAL
    MIXED
}

enum HtfRegime {
    MACRO_BULLISH
    BULL_EXTENDED
    MACRO_BEARISH
    BEAR_EXTENDED
    RECLAIMING
    RANGING
    ACCUMULATION
    DISTRIBUTION
}

enum MarketStructure {
    HH_HL
    LH_LL
    HH_LL
    LH_HL
    STRUCTURE_UNKNOWN
}

enum OiSignal {
    EXTREME
    ELEVATED
    OI_NORMAL
    DEPRESSED
}

enum SentimentRegime {
    EXTREME_FEAR
    FEAR
    SENTIMENT_NEUTRAL
    GREED
    EXTREME_GREED
    CONSENSUS_BULLISH
    CONSENSUS_BEARISH
    SENTIMENT_DIVERGENCE
}

// ─── Dimension Regime State (mutable singleton per asset+dimension) ──────────

model DimensionState {
    id             String    @id @default(cuid())
    asset          Asset
    dimension      Dimension
    regime         String
    since          DateTime
    previousRegime String?
    lastUpdated    DateTime  @updatedAt

    // Derivatives-specific
    stress         String?
    previousStress String?

    // HTF-specific
    lastStructure  String?

    @@unique([asset, dimension])
    @@index([asset])
    @@map("dimension_states")
}

// ─── Dimension Snapshots (raw time-series data) ──────────────────────────────

model DimensionSnapshot {
    id        String    @id @default(cuid())
    asset     Asset
    dimension Dimension
    timestamp DateTime
    data      Json

    @@index([asset, dimension, timestamp])
    @@map("dimension_snapshots")
}

// ─── Briefs ──────────────────────────────────────────────────────────────────

model Brief {
    id         String      @id @default(cuid())
    asset      Asset
    timestamp  DateTime    @default(now())
    brief      String
    richBrief  Json?
    dimensions Dimension[]

    // Relations to per-dimension models
    derivatives DerivativesDimension?
    etfs        EtfsDimension?
    htf         HtfDimension?
    sentiment   SentimentDimension?

    @@index([asset, timestamp])
    @@map("briefs")
}

// ─── Per-Dimension Brief Models ──────────────────────────────────────────────

model DerivativesDimension {
    id             String             @id @default(cuid())
    briefId        String             @unique
    brief          Brief              @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime         PositioningRegime
    stress         StressLevel?
    previousRegime PositioningRegime?
    previousStress StressLevel?
    oiSignal       OiSignal?
    since          DateTime
    context        Json
    interpretation String

    @@map("brief_derivatives")
}

model EtfsDimension {
    id             String     @id @default(cuid())
    briefId        String     @unique
    brief          Brief      @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime         EtfRegime
    previousRegime EtfRegime?
    since          DateTime
    context        Json
    interpretation String

    @@map("brief_etfs")
}

model HtfDimension {
    id             String           @id @default(cuid())
    briefId        String           @unique
    brief          Brief            @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime         HtfRegime
    previousRegime HtfRegime?
    since          DateTime
    lastStructure  MarketStructure?
    snapshotPrice  Float?
    context        Json
    interpretation String

    @@map("brief_htf")
}

model SentimentDimension {
    id                 String          @id @default(cuid())
    briefId            String          @unique
    brief              Brief           @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime             SentimentRegime
    previousRegime     SentimentRegime?
    since              DateTime
    compositeIndex     Float?
    compositeLabel     String?
    positioning        Float?
    trend              Float?
    institutionalFlows Float?
    expertConsensus    Float?
    context            Json
    interpretation     String

    @@map("brief_sentiment")
}
