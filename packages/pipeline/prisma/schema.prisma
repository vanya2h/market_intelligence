generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ─── Core Enums ──────────────────────────────────────────────────────────────

enum Asset {
    BTC
    ETH
}

enum Dimension {
    DERIVATIVES
    ETFS
    HTF
    SENTIMENT
    EXCHANGE_FLOWS
}

// ─── Per-Dimension Regime Enums ──────────────────────────────────────────────

enum PositioningRegime {
    CROWDED_LONG
    CROWDED_SHORT
    HEATING_UP
    POSITIONING_NEUTRAL
}

enum StressLevel {
    CAPITULATION
    UNWINDING
    DELEVERAGING
    STRESS_NONE
}

enum EtfRegime {
    STRONG_INFLOW
    STRONG_OUTFLOW
    REVERSAL_TO_INFLOW
    REVERSAL_TO_OUTFLOW
    ETF_NEUTRAL
    MIXED
}

enum HtfRegime {
    MACRO_BULLISH
    BULL_EXTENDED
    MACRO_BEARISH
    BEAR_EXTENDED
    RECLAIMING
    RANGING
    ACCUMULATION
    DISTRIBUTION
}

enum MarketStructure {
    HH_HL
    LH_LL
    HH_LL
    LH_HL
    STRUCTURE_UNKNOWN
}

enum OiSignal {
    EXTREME
    ELEVATED
    OI_NORMAL
    DEPRESSED
}

enum ExchangeFlowsRegime {
    ACCUMULATION
    DISTRIBUTION
    EF_NEUTRAL
    HEAVY_INFLOW
    HEAVY_OUTFLOW
}

enum SentimentRegime {
    EXTREME_FEAR
    FEAR
    SENTIMENT_NEUTRAL
    GREED
    EXTREME_GREED
    CONSENSUS_BULLISH
    CONSENSUS_BEARISH
    SENTIMENT_DIVERGENCE
}

// ─── Notify Run (resumable pipeline tracking) ───────────────────────────────

enum NotifyStage {
    DIMENSIONS
    TRADE_IDEA
    SYNTHESIS
    PERSIST
    TELEGRAM
    TWITTER
}

enum RunStatus {
    RUNNING
    COMPLETED
    FAILED
}

model NotifyRun {
    id            String       @id @default(cuid())
    asset         Asset
    status        RunStatus    @default(RUNNING)
    lastCompleted NotifyStage?
    failedStage   NotifyStage?
    error         String?
    artifacts     Json?
    briefId       String?
    brief         Brief?       @relation(fields: [briefId], references: [id], onDelete: SetNull)
    createdAt     DateTime     @default(now())
    updatedAt     DateTime     @updatedAt

    @@index([asset, createdAt])
    @@index([status])
    @@map("notify_runs")
}

// ─── Dimension Regime State (mutable singleton per asset+dimension) ──────────

model DimensionState {
    id             String    @id @default(cuid())
    asset          Asset
    dimension      Dimension
    regime         String
    since          DateTime
    previousRegime String?
    lastUpdated    DateTime  @updatedAt

    // Derivatives-specific
    stress         String?
    previousStress String?

    // HTF-specific
    lastStructure String?

    @@unique([asset, dimension])
    @@index([asset])
    @@map("dimension_states")
}

// ─── Dimension Snapshots (raw time-series data) ──────────────────────────────

model DimensionSnapshot {
    id        String    @id @default(cuid())
    asset     Asset
    dimension Dimension
    timestamp DateTime
    data      Json

    @@index([asset, dimension, timestamp])
    @@map("dimension_snapshots")
}

// ─── Briefs ──────────────────────────────────────────────────────────────────

model Brief {
    id         String      @id @default(cuid())
    asset      Asset
    timestamp  DateTime    @default(now())
    brief      String
    richBrief  Json?
    dimensions Dimension[]

    // Relations to per-dimension models
    derivatives   DerivativesDimension?
    etfs          EtfsDimension?
    htf           HtfDimension?
    sentiment     SentimentDimension?
    exchangeFlows ExchangeFlowsDimension?
    tradeIdea     TradeIdea?
    notifyRuns    NotifyRun[]

    @@index([asset, timestamp])
    @@map("briefs")
}

// ─── Per-Dimension Brief Models ──────────────────────────────────────────────

model DerivativesDimension {
    id             String             @id @default(cuid())
    briefId        String             @unique
    brief          Brief              @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime         PositioningRegime
    stress         StressLevel?
    previousRegime PositioningRegime?
    previousStress StressLevel?
    oiSignal       OiSignal?
    since          DateTime
    context        Json
    interpretation String

    @@map("brief_derivatives")
}

model EtfsDimension {
    id             String     @id @default(cuid())
    briefId        String     @unique
    brief          Brief      @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime         EtfRegime
    previousRegime EtfRegime?
    since          DateTime
    context        Json
    interpretation String

    @@map("brief_etfs")
}

model HtfDimension {
    id             String           @id @default(cuid())
    briefId        String           @unique
    brief          Brief            @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime         HtfRegime
    previousRegime HtfRegime?
    since          DateTime
    lastStructure  MarketStructure?
    snapshotPrice  Float?
    context        Json
    interpretation String

    @@map("brief_htf")
}

model SentimentDimension {
    id                 String           @id @default(cuid())
    briefId            String           @unique
    brief              Brief            @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime             SentimentRegime
    previousRegime     SentimentRegime?
    since              DateTime
    compositeIndex     Float?
    compositeLabel     String?
    positioning        Float?
    trend              Float?
    institutionalFlows Float?
    exchangeFlows      Float?
    expertConsensus    Float?
    context            Json
    interpretation     String

    @@map("brief_sentiment")
}

model ExchangeFlowsDimension {
    id             String               @id @default(cuid())
    briefId        String               @unique
    brief          Brief                @relation(fields: [briefId], references: [id], onDelete: Cascade)
    regime         ExchangeFlowsRegime
    previousRegime ExchangeFlowsRegime?
    since          DateTime
    context        Json
    interpretation String

    @@map("brief_exchange_flows")
}

// ─── Trade Idea Enums ────────────────────────────────────────────────────────

enum TradeDirection {
    LONG
    SHORT
    FLAT
}

enum TradeOutcome {
    OPEN
    WIN
    LOSS
}

enum LevelType {
    INVALIDATION
    TARGET
}

// ─── Trade Idea Tracking ─────────────────────────────────────────────────────

model TradeIdea {
    id              String         @id @default(cuid())
    briefId         String         @unique
    brief           Brief          @relation(fields: [briefId], references: [id], onDelete: Cascade)
    asset           Asset
    direction       TradeDirection
    entryPrice      Float
    compositeTarget Float
    confluence      Json? // { derivatives, etfs, htf, exchangeFlows, total, bias, weights, sizing } — per-dim and total in -1..+1
    positionSizePct Float          @default(0) // recommended position size as % of account notional (5–150)
    // deprecated
    skipped         Boolean        @default(false) // true when conviction < threshold
    createdAt       DateTime       @default(now())

    levels  TradeIdeaLevel[]
    returns TradeIdeaReturn[]

    @@index([asset, createdAt])
    @@map("trade_ideas")
}

model TradeIdeaLevel {
    id           String       @id @default(cuid())
    tradeIdeaId  String
    tradeIdea    TradeIdea    @relation(fields: [tradeIdeaId], references: [id], onDelete: Cascade)
    type         LevelType // INVALIDATION (stop loss) or TARGET (take profit)
    label        String // e.g. "1:3" for invalidation, "T1" / "T2" / "T3" for target
    price        Float // the price level (or distance for FLAT ideas)
    outcome      TradeOutcome @default(OPEN)
    qualityScore Float?
    resolvedAt   DateTime?

    @@unique([tradeIdeaId, type, label])
    @@index([tradeIdeaId])
    @@index([outcome])
    @@index([type, outcome])
    @@map("trade_idea_levels")
}

model TradeIdeaReturn {
    id             String    @id @default(cuid())
    tradeIdeaId    String
    tradeIdea      TradeIdea @relation(fields: [tradeIdeaId], references: [id], onDelete: Cascade)
    hoursAfter     Int
    price          Float
    returnPct      Float
    qualityAtPoint Float

    @@unique([tradeIdeaId, hoursAfter])
    @@index([tradeIdeaId])
    @@map("trade_idea_returns")
}
